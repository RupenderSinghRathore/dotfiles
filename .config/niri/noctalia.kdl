layout {

    focus-ring {
        active-color   "#ffb874"
        inactive-color "#17120f"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#ffb874"
        inactive-color "#17120f"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb874"
        inactive-color "#6b3b00"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb87480"
    }
}

recent-windows {
    highlight {
        active-color "#ffb874"
        urgent-color "#ffb4ab"
    }
}
